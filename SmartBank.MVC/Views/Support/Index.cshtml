@model SmartBank.MVC.ViewModels.TicketListViewModel
@{ ViewData["Title"] = "Support Tickets"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-ticket-detailed me-2"></i>My Support Tickets
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Raise Ticket
    </a>
</div>

@if (!Model.Tickets.Any())
{
    <div class="card p-5 text-center">
        <i class="bi bi-ticket-detailed text-muted" style="font-size:3rem"></i>
        <h5 class="mt-3 text-muted">No support tickets yet</h5>
        <p class="text-muted small">Raise a ticket if you need help.</p>
        <a asp-action="Create" class="btn btn-primary mx-auto" style="width:fit-content">
            <i class="bi bi-plus-circle me-1"></i> Raise Ticket
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Raised On</th>
                        <th>Resolved On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model.Tickets)
                    {
                        var statusColor = ticket.Status switch
                        {
                            "Resolved" => "success",
                            "InProgress" => "warning",
                            _ => "danger"
                        };

                        <tr>
                            <td class="ps-4 text-muted small">#@ticket.TicketId</td>
                            <td>
                                <div class="fw-semibold small">@ticket.Subject</div>
                                <div class="text-muted" style="font-size:.78rem">
                                    @(ticket.Description.Length > 60
                                        ? ticket.Description[..60] + "..."
                                        : ticket.Description)
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-@statusColor">@ticket.Status</span>
                            </td>
                            <td class="small text-muted">
                                @ticket.CreatedAt.ToString("dd MMM yyyy")
                            </td>
                            <td class="small text-muted">
                                @(ticket.ResolvedAt.HasValue
                                    ? ticket.ResolvedAt.Value.ToString("dd MMM yyyy")
                                    : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}