@model SmartBank.MVC.ViewModels.PassbookViewModel
@{
    ViewData["Title"] = "Passbook - Print Preview";
    var numberOfTransactions = ViewData["NumberOfTransactions"] ?? 10;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Passbook - SmartBank</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        @@media print {
            body {
                background: white;
                margin: 0;
                padding: 0;
            }

            .print-container {
                width: 100%;
                max-width: 100%;
            }

            .card {
                page-break-inside: avoid;
                box-shadow: none !important;
                border: 1px solid #ccc;
                margin-bottom: 20px;
            }

            .card-header {
                background-color: #f0f0f0 !important;
                border-bottom: 2px solid #333;
                color: #000 !important;
            }

            .card-header h5 {
                color: #000 !important;
            }

            .btn, .no-print {
                display: none !important;
            }

            table {
                width: 100%;
                margin: 0;
            }

            .table-hover tbody tr:hover {
                background-color: transparent !important;
            }

            .footer-info {
                margin-top: 30px;
                padding-top: 20px;
                border-top: 1px solid #ccc;
                font-size: 11px;
                color: #666;
            }
        }

        body {
            background-color: #f5f5f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .print-container {
            background: white;
            padding: 40px;
            margin: 20px auto;
            max-width: 900px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        .print-header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 3px solid #005EB8;
            padding-bottom: 15px;
        }

        .print-header h1 {
            color: #005EB8;
            margin: 0;
            font-size: 28px;
            font-weight: bold;
        }

        .print-header p {
            color: #666;
            margin: 5px 0 0 0;
            font-size: 14px;
        }

        .account-info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-item {
            padding: 15px;
            background-color: #f9f9f9;
            border-left: 4px solid #005EB8;
        }

        .info-label {
            font-size: 12px;
            color: #666;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        .transactions-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .transactions-table thead {
            background-color: #005EB8;
            color: white;
        }

        .transactions-table th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            border: 1px solid #ddd;
        }

        .transactions-table td {
            padding: 10px 12px;
            border: 1px solid #eee;
            font-size: 13px;
        }

        .transactions-table tbody tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .amount-positive {
            color: #28a745;
            font-weight: 600;
        }

        .amount-negative {
            color: #dc3545;
            font-weight: 600;
        }

        .summary-section {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-top: 30px;
        }

        .summary-item {
            padding: 15px;
            border: 1px solid #ddd;
            text-align: center;
            background-color: #f9f9f9;
        }

        .summary-label {
            font-size: 12px;
            color: #666;
            margin-bottom: 8px;
        }

        .summary-value {
            font-size: 18px;
            font-weight: bold;
            color: #005EB8;
        }

        .footer-info {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #ccc;
            font-size: 11px;
            color: #999;
        }

        .no-print {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
        }

        @@media (max-width: 768px) {
            .print-container {
                padding: 20px;
                margin: 10px;
            }

            .account-info-grid {
                grid-template-columns: 1fr;
            }

            .summary-section {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="btn btn-primary btn-sm" onclick="window.print()">
            <i class="bi bi-printer"></i> Print / Save as PDF
        </button>
        <a href="/Passbook/Index" class="btn btn-secondary btn-sm">Back</a>
    </div>

    @if (Model != null)
    {
        <div class="print-container">
            <!-- Header -->
            <div class="print-header">
                <h1>SmartBank</h1>
                <p>ACCOUNT PASSBOOK</p>
            </div>

            <!-- Account Information -->
            <div class="account-info-grid">
                <div class="info-item">
                    <div class="info-label">Account Number</div>
                    <div class="info-value">@Model.AccountNumber</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Account Type</div>
                    <div class="info-value">@Model.AccountType</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Account Holder</div>
                    <div class="info-value">@Model.UserName</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Email</div>
                    <div class="info-value">@Model.UserEmail</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Account Opened</div>
                    <div class="info-value">@Model.AccountOpenedAt.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Current Balance</div>
                    <div class="info-value" style="color: #28a745;">₹@Model.CurrentBalance.ToString("N2")</div>
                </div>
            </div>

            <!-- Transactions -->
            <h3 style="color: #005EB8; margin-top: 30px; margin-bottom: 15px; font-size: 18px;">
                Transaction History (Last @numberOfTransactions Transactions)
            </h3>

            @if (Model.Transactions != null && Model.Transactions.Count > 0)
            {
                var deposits = Model.Transactions.Where(t => t.Type == "Deposit").Sum(t => (decimal)t.Amount);
                var withdrawals = Model.Transactions.Where(t => t.Type == "Withdrawal").Sum(t => (decimal)t.Amount);

                <table class="transactions-table">
                    <thead>
                        <tr>
                            <th width="18%">Date</th>
                            <th width="12%">Type</th>
                            <th width="15%">Amount</th>
                            <th width="35%">Description</th>
                            <th width="15%">Balance</th>
                            <th width="5%">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.Transactions.OrderByDescending(t => t.CreatedAt))
                        {
                            var isDeposit = tx.Type == "Deposit";
                            var isTransferIn = tx.Type == "Transfer In";
                            <tr>
                                <td>@tx.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@tx.Type</td>
                                <td class="@((isDeposit || isTransferIn) ? "amount-positive" : "amount-negative")">
                                    @if (isDeposit || isTransferIn)
                                    {
                                        <text>+₹@tx.Amount.ToString("N2")</text>
                                    }
                                    else
                                    {
                                        <text>-₹@tx.Amount.ToString("N2")</text>
                                    }
                                </td>
                                <td>
                                    <div>@tx.Description</div>
                                    @if (!string.IsNullOrEmpty(tx.OtherPartyName))
                                    {
                                        <div style="font-size: 11px; color: #666; margin-top: 3px;">
                                            @if (tx.Type == "Transfer Out")
                                            {
                                                <text>→ To: @tx.OtherPartyName (@tx.OtherPartyAccountNumber)</text>
                                            }
                                            else if (tx.Type == "Transfer In")
                                            {
                                                <text>← From: @tx.OtherPartyName (@tx.OtherPartyAccountNumber)</text>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>₹@tx.BalanceAfter.ToString("N2")</td>
                                <td>✓</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="summary-section">
                    <div class="summary-item">
                        <div class="summary-label">Total Deposits</div>
                        <div class="summary-value" style="color: #28a745;">+₹@deposits.ToString("N2")</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Total Withdrawals</div>
                        <div class="summary-value" style="color: #dc3545;">-₹@withdrawals.ToString("N2")</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Net Change</div>
                        <div class="summary-value">₹@((deposits - withdrawals).ToString("N2"))</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Current Balance</div>
                        <div class="summary-value" style="color: #005EB8;">₹@Model.CurrentBalance.ToString("N2")</div>
                    </div>
                </div>
            }
            else
            {
                <p style="text-align: center; color: #999;">No transactions found for this account.</p>
            }

            <div class="footer-info">
                <p>
                    Generated on: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")<br />
                    This is a digital passbook for account @Model.AccountNumber
                </p>
                <p style="margin-top: 10px;">
                    For official records and inquiries, please contact SmartBank directly.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="print-container">
            <div class="alert alert-danger">
                Error loading passbook data. Please try again.
            </div>
        </div>
    }
</body>
</html>
