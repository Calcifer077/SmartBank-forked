@model SmartBank.MVC.ViewModels.PassbookViewModel
@{
    ViewData["Title"] = "Passbook View";
    var numberOfTransactions = ViewData["NumberOfTransactions"] ?? 10;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <a href="/Passbook/Index" class="btn btn-secondary btn-sm mb-3">
                <i class="bi bi-arrow-left"></i> Back to Passbook Selection
            </a>
            <h2><i class="bi bi-book"></i> Passbook Details</h2>
        </div>
    </div>

    @if (Model != null)
    {
        <div class="row">
            <div class="col-md-12">
                <!-- Account Header -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Account Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="info-section">
                                    <small class="text-muted">Account Number</small>
                                    <p class="mb-0 font-weight-bold">@Model.AccountNumber</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="info-section">
                                    <small class="text-muted">Account Holder</small>
                                    <p class="mb-0 font-weight-bold">@Model.UserName</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="info-section">
                                    <small class="text-muted">Account Type</small>
                                    <p class="mb-0 font-weight-bold">@Model.AccountType</p>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="info-section">
                                    <small class="text-muted">Current Balance</small>
                                    <p class="mb-0 font-weight-bold text-success">₹@Model.CurrentBalance.ToString("N2")</p>
                                </div>
                            </div>
                        </div>
                        <hr />
                        <div class="row">
                            <div class="col-md-3">
                                <small class="text-muted">Email</small>
                                <p class="mb-0">@Model.UserEmail</p>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted">Account Opened</small>
                                <p class="mb-0">@Model.AccountOpenedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="col-md-6 text-end">
                                <button type="button" class="btn btn-success btn-sm" onclick="window.print()">
                                    <i class="bi bi-printer"></i> Print as PDF
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transactions Table -->
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Transaction History (Last @numberOfTransactions Transactions)</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Transactions != null && Model.Transactions.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Amount</th>
                                            <th>Description</th>
                                            <th>Balance After</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var tx in Model.Transactions.OrderByDescending(t => t.CreatedAt))
                                        {
                                            var isDeposit = tx.Type == "Deposit";
                                            <tr class="@(isDeposit ? "table-success" : "")">
                                                <td>@tx.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                                <td>
                                                    @if (tx.Type.Contains("Deposit"))
                                                    {
                                                        <span class="badge bg-success">@tx.Type</span>
                                                    }
                                                    else if (tx.Type.Contains("Transfer"))
                                                    {
                                                        <span class="badge bg-info">@tx.Type</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">@tx.Type</span>
                                                    }
                                                </td>
                                                <td class="fw-bold">
                                                    @if (tx.Type == "Deposit" || tx.Type == "Transfer In")
                                                    {
                                                        <span class="text-success">+₹@tx.Amount.ToString("N2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">-₹@tx.Amount.ToString("N2")</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="small">
                                                        <div>@tx.Description</div>
                                                        @if (!string.IsNullOrEmpty(tx.OtherPartyName))
                                                        {
                                                            <div class="text-primary fw-semibold mt-1">
                                                                @if (tx.Type == "Transfer Out")
                                                                {
                                                                    <text><i class="bi bi-arrow-right"></i> To: @tx.OtherPartyName</text>
                                                                }
                                                                else if (tx.Type == "Transfer In")
                                                                {
                                                                    <text><i class="bi bi-arrow-left"></i> From: @tx.OtherPartyName</text>
                                                                }
                                                            </div>
                                                            <div class="text-muted font-monospace">@tx.OtherPartyAccountNumber</div>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="fw-bold">₹@tx.BalanceAfter.ToString("N2")</td>
                                                <td>
                                                    <span class="badge bg-info">Completed</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="bi bi-inbox"></i> No transactions found for this account.
                            </div>
                        }
                    </div>
                </div>

                <!-- Summary Footer -->
                @if (Model.Transactions != null && Model.Transactions.Count > 0)
                {
                    var deposits = Model.Transactions.Where(t => t.Type == "Deposit").Sum(t => (decimal)t.Amount);
                    var withdrawals = Model.Transactions.Where(t => t.Type == "Withdrawal").Sum(t => (decimal)t.Amount);

                    <div class="card mt-4">
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-3">
                                    <p class="text-muted">Total Deposits</p>
                                    <p class="h5 text-success">+₹@deposits.ToString("N2")</p>
                                </div>
                                <div class="col-md-3">
                                    <p class="text-muted">Total Withdrawals</p>
                                    <p class="h5 text-danger">-₹@withdrawals.ToString("N2")</p>
                                </div>
                                <div class="col-md-3">
                                    <p class="text-muted">Net Change</p>
                                    <p class="h5">₹@((deposits - withdrawals).ToString("N2"))</p>
                                </div>
                                <div class="col-md-3">
                                    <p class="text-muted">Current Balance</p>
                                    <p class="h5 text-primary">₹@Model.CurrentBalance.ToString("N2")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> Error loading passbook data. Please try again.
        </div>
    }
</div>

<style>
    .info-section {
        padding: 10px;
    }

    .table-responsive {
        max-height: 600px;
        overflow-y: auto;
    }

    @@media (max-width: 768px) {
        .info-section {
            margin-bottom: 15px;
        }
    }
</style>
