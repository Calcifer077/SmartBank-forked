@model SmartBank.MVC.ViewModels.LoanListViewModel
@{ ViewData["Title"] = "My Loans"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2"></i>My Loans</h4>
    @if (!Model.HasPending)
    {
        <a asp-action="Apply" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Apply for Loan
        </a>
    }
</div>

@if (Model.HasPending)
{
    <div class="alert alert-info d-flex gap-2 align-items-center mb-4">
        <i class="bi bi-hourglass-split"></i>
        <div>
            You have a <strong>pending loan</strong> under review.
            You cannot apply for another loan until it is reviewed.
        </div>
    </div>
}

@if (!Model.Loans.Any())
{
    <div class="card p-5 text-center">
        <i class="bi bi-cash-stack text-muted" style="font-size:3rem"></i>
        <h5 class="mt-3 text-muted">No loan applications yet</h5>
        <p class="text-muted small">Apply for a loan to get started.</p>
        <a asp-action="Apply" class="btn btn-primary mx-auto" style="width:fit-content">
            <i class="bi bi-plus-circle me-1"></i> Apply Now
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var loan in Model.Loans)
        {
            var statusColor = loan.Status switch
            {
                "Approved" => "success",
                "Rejected" => "danger",
                _ => "warning"
            };
            var statusIcon = loan.Status switch
            {
                "Approved" => "check-circle",
                "Rejected" => "x-circle",
                _ => "hourglass-split"
            };

            <div class="col-md-6">
                <div class="card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="fw-bold mb-0">₹@loan.Amount.ToString("N2")</h5>
                            <small class="text-muted">@loan.TermMonths months</small>
                        </div>
                        <span class="badge bg-@statusColor">
                            <i class="bi bi-@statusIcon me-1"></i>@loan.Status
                        </span>
                    </div>

                    <p class="text-muted small mb-2">
                        <i class="bi bi-tag me-1"></i>@loan.Purpose
                    </p>

                    <div class="d-flex justify-content-between small text-muted mb-3">
                        <span>Monthly: <strong class="text-dark">
                            ₹@loan.MonthlyPayment.ToString("N2")
                        </strong></span>
                        <span>Applied: @loan.AppliedAt.ToString("dd MMM yyyy")</span>
                    </div>

                    <a asp-action="Detail" asp-route-id="@loan.LoanId"
                       class="btn btn-outline-primary btn-sm mt-auto">
                        View Details <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}