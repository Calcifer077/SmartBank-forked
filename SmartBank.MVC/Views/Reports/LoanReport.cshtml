@model SmartBank.MVC.ViewModels.LoanReportViewModel
@{ ViewData["Title"] = "Loan Report"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-cash-stack me-2"></i>Loan Approvals Report
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Reports
    </a>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card p-3 text-center">
            <small class="text-muted">Total Applications</small>
            <h4 class="fw-bold mb-0">@Model.Loans.Count</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center bg-success bg-opacity-10">
            <small class="text-muted">Approved</small>
            <h4 class="fw-bold text-success mb-0">@Model.TotalApproved</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center bg-danger bg-opacity-10">
            <small class="text-muted">Rejected</small>
            <h4 class="fw-bold text-danger mb-0">@Model.TotalRejected</h4>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center bg-primary bg-opacity-10">
            <small class="text-muted">Total Approved Amount</small>
            <h4 class="fw-bold text-primary mb-0">
                ₹@Model.TotalApprovedAmount.ToString("N0")
            </h4>
        </div>
    </div>
</div>

<!-- Loans Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Amount</th>
                    <th>Term</th>
                    <th>Purpose</th>
                    <th>Status</th>
                    <th class="pe-4">Applied Date</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Loans.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            No loan applications
                        </td>
                    </tr>
                }
                @foreach (var loan in Model.Loans)
                {
                    var statusClass = loan.Status == "Approved" ? "success" :
                                      loan.Status == "Rejected" ? "danger" : "warning";
                    <tr>
                        <td class="ps-4 text-muted small">#@loan.LoanId</td>
                        <td class="fw-semibold">@loan.CustomerName</td>
                        <td class="text-muted small">@loan.CustomerEmail</td>
                        <td class="fw-semibold">₹@loan.Amount.ToString("N0")</td>
                        <td class="text-center">@loan.TermMonths months</td>
                        <td>
                            <small>@loan.Purpose</small>
                        </td>
                        <td>
                            <span class="badge bg-@statusClass">@loan.Status</span>
                        </td>
                        <td class="pe-4 text-muted small">
                            @loan.AppliedAt.ToString("dd MMM yyyy")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
