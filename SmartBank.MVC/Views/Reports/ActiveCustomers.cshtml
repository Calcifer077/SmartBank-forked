@model SmartBank.MVC.ViewModels.ActiveCustomersReportViewModel
@{ ViewData["Title"] = "Active Customers"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-people me-2"></i>Active Customers
        <span class="badge bg-primary ms-2">@Model.Customers.Count</span>
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Reports
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Customer</th>
                    <th>Phone</th>
                    <th>KYC Status</th>
                    <th>Accounts</th>
                    <th class="pe-4">Member Since</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Customers.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            No active customers
                        </td>
                    </tr>
                }
                @foreach (var c in Model.Customers)
                {
                    var kycColor = c.KycStatus == "Verified" ? "success" :
                                   c.KycStatus == "Rejected" ? "danger" : "warning";
                    <tr>
                        <td class="ps-4 text-muted small">#@c.UserId</td>
                        <td>
                            <div class="fw-semibold small">@c.FullName</div>
                            <div class="text-muted" style="font-size:.75rem">@c.Email</div>
                        </td>
                        <td class="small text-muted">@c.PhoneNumber</td>
                        <td>
                            <span class="badge bg-@kycColor">@c.KycStatus</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark">@c.AccountCount</span>
                        </td>
                        <td class="small text-muted pe-4">
                            @c.CreatedAt.ToString("dd MMM yyyy")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
