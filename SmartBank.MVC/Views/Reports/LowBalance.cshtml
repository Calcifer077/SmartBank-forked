@model SmartBank.MVC.ViewModels.LowBalanceReportViewModel
@{ ViewData["Title"] = "Low Balance Accounts"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-exclamation-triangle me-2 text-danger"></i>Low Balance Accounts
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Reports
    </a>
</div>

<!-- Threshold Filter -->
<div class="card p-3 mb-4">
    <form method="get" class="d-flex align-items-center gap-3">
        <label class="fw-semibold small mb-0">Balance below:</label>
        <div class="input-group" style="width:200px">
            <span class="input-group-text">₹</span>
            <input type="number" name="threshold" class="form-control form-control-sm"
                   value="@Model.Threshold" min="0" />
        </div>
        <button class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i> Filter
        </button>
    </form>
</div>

<div class="alert alert-warning d-flex gap-2 small">
    <i class="bi bi-info-circle-fill mt-1"></i>
    <span>
        Showing <strong>@Model.Accounts.Count</strong> active accounts with balance below 
        <strong>₹@Model.Threshold.ToString("N2")</strong>
    </span>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Account Number</th>
                    <th>Type</th>
                    <th>Owner</th>
                    <th>Email</th>
                    <th class="text-end pe-4">Balance</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Accounts.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No accounts below ₹@Model.Threshold.ToString("N2")
                        </td>
                    </tr>
                }
                @foreach (var account in Model.Accounts)
                {
                    var balanceClass = account.Balance < 500 ? "danger" : "warning";
                    <tr>
                        <td class="ps-4 font-monospace small">@account.AccountNumber</td>
                        <td>
                            <span class="badge bg-light text-dark">@account.AccountType</span>
                        </td>
                        <td class="fw-semibold">@account.OwnerName</td>
                        <td class="text-muted small">@account.OwnerEmail</td>
                        <td class="pe-4 text-end">
                            <span class="fw-bold text-@balanceClass">
                                ₹@account.Balance.ToString("N2")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
