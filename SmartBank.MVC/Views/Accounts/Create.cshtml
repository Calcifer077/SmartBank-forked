@model SmartBank.MVC.ViewModels.AccountCreateViewModel
@{ ViewData["Title"] = "Open Account"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center mt-2">
    <div class="col-md-6">
        <div class="card p-4">
            <div class="text-center mb-4">
                <i class="bi bi-plus-circle text-primary" style="font-size:2.5rem"></i>
                <h4 class="mt-2 fw-bold">Open New Account</h4>
                <p class="text-muted small">Choose the type of account you want to open</p>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 small"></div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Account Type</label>

                    <div class="row g-3">
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="AccountType"
                                   id="savings" value="Savings" />
                            <label class="btn btn-outline-primary w-100 py-4" for="savings">
                                <i class="bi bi-piggy-bank d-block mb-2"
                                   style="font-size:2rem"></i>
                                <strong>Savings</strong>
                                <div class="small text-muted mt-1">
                                    Earn interest on deposits
                                </div>
                            </label>
                        </div>
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="AccountType"
                                   id="current" value="Current" />
                            <label class="btn btn-outline-success w-100 py-4" for="current">
                                <i class="bi bi-briefcase d-block mb-2"
                                   style="font-size:2rem"></i>
                                <strong>Current</strong>
                                <div class="small text-muted mt-1">
                                    For business transactions
                                </div>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="AccountType"
                          class="text-danger small"></span>
                </div>

                <div class="alert alert-light border small">
                    <i class="bi bi-info-circle me-1"></i>
                    Account opens with ₹0 balance. Deposit funds after creation.
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-check-circle me-1"></i> Open Account
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>