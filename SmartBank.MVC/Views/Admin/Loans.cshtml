@model SmartBank.MVC.ViewModels.AdminLoanListViewModel
@{ ViewData["Title"] = "Loan Approvals"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-cash-stack me-2"></i>Loan Applications
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Dashboard
    </a>
</div>

<!-- Summary Pills -->
<div class="d-flex gap-2 mb-4">
    <span class="badge bg-warning text-dark fs-6 px-3 py-2">
        Pending: @Model.Loans.Count(l => l.Status == "Pending")
    </span>
    <span class="badge bg-success fs-6 px-3 py-2">
        Approved: @Model.Loans.Count(l => l.Status == "Approved")
    </span>
    <span class="badge bg-danger fs-6 px-3 py-2">
        Rejected: @Model.Loans.Count(l => l.Status == "Rejected")
    </span>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Term</th>
                    <th>Purpose</th>
                    <th>Applied</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in Model.Loans)
                {
                    var statusColor = loan.Status switch
                    {
                        "Approved" => "success",
                        "Rejected" => "danger",
                        _ => "warning"
                    };

                    <tr>
                        <td class="ps-4 text-muted small">#@loan.LoanId</td>
                        <td>
                            <div class="fw-semibold small">@loan.CustomerName</div>
                            <div class="text-muted" style="font-size:.78rem">
                                @loan.CustomerEmail
                            </div>
                        </td>
                        <td class="fw-semibold">₹@loan.Amount.ToString("N2")</td>
                        <td class="small">@loan.TermMonths mo</td>
                        <td class="small text-muted">@loan.Purpose</td>
                        <td class="small text-muted">
                            @loan.AppliedAt.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <span class="badge bg-@statusColor">@loan.Status</span>
                        </td>
                        <td class="text-end pe-4">
                            @if (loan.Status == "Pending")
                            {
                                <form asp-action="ReviewLoan" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="loanId" value="@loan.LoanId" />
                                    <input type="hidden" name="decision" value="Approved" />
                                    <button class="btn btn-success btn-sm">
                                        <i class="bi bi-check me-1"></i>Approve
                                    </button>
                                </form>
                                <form asp-action="ReviewLoan" method="post"
                                      class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="loanId" value="@loan.LoanId" />
                                    <input type="hidden" name="decision" value="Rejected" />
                                    <button class="btn btn-danger btn-sm">
                                        <i class="bi bi-x me-1"></i>Reject
                                    </button>
                                </form>
                            }
                            else
                            {
                                <small class="text-muted">
                                    @loan.ReviewedAt?.ToString("dd MMM yyyy")
                                </small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>