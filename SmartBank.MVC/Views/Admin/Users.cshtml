@model SmartBank.MVC.ViewModels.AdminUserListViewModel
@{ ViewData["Title"] = "Manage Users"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-people me-2"></i>Manage Users
        <span class="badge bg-primary ms-2">@Model.Users.Count</span>
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Dashboard
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>User Info</th>
                    <th>Contact</th>
                    <th>Role</th>
                    <th>KYC Status</th>
                    <th>Accounts</th>
                    <th class="text-center">Status</th>
                    <th class="pe-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            No users found
                        </td>
                    </tr>
                }
                @foreach (var user in Model.Users)
                {
                    var kycBadgeClass = user.KycStatus == "Verified" ? "success" :
                                        user.KycStatus == "Rejected" ? "danger" : "warning";
                    var statusBadgeClass = user.IsActive ? "success" : "danger";
                    <tr>
                        <td class="ps-4 text-muted small">#@user.UserId</td>
                        <td>
                            <div class="fw-semibold">@user.FullName</div>
                            <div class="text-muted small">@user.Email</div>
                        </td>
                        <td class="text-muted small">@user.PhoneNumber</td>
                        <td>
                            <span class="badge bg-info">@user.Role</span>
                        </td>
                        <td>
                            <span class="badge bg-@kycBadgeClass">@user.KycStatus</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark">@user.AccountCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-@statusBadgeClass">
                                @(user.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="pe-4 text-center">
                            <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" 
                                    data-bs-target="#roleModal" 
                                    onclick="setUserRole(@user.UserId, '@user.FullName', '@user.Role')"
                                    title="Change user role">
                                <i class="bi bi-person-badge"></i> Role
                            </button>
                            @if (user.IsActive)
                            {
                                <form asp-action="FreezeAccount" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="accountId" value="@user.UserId" />
                                    <input type="hidden" name="action" value="Freeze" />
                                    <input type="hidden" name="returnTo" value="Users" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning" 
                                            title="Freeze this user's account(s)" 
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            onclick="return confirm('Are you sure? This will freeze all accounts for this user.');">
                                        <i class="bi bi-lock"></i> Freeze
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="FreezeAccount" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="accountId" value="@user.UserId" />
                                    <input type="hidden" name="action" value="Unfreeze" />
                                    <input type="hidden" name="returnTo" value="Users" />
                                    <button type="submit" class="btn btn-sm btn-outline-success"
                                            title="Unfreeze this user's account(s)" 
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            onclick="return confirm('Are you sure? This will unfreeze all accounts for this user?');">
                                        <i class="bi bi-unlock"></i> Unfreeze
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Role Change Modal -->
<div class="modal fade" id="roleModal" tabindex="-1" aria-labelledby="roleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="roleModalLabel">
                    <i class="bi bi-person-badge me-2"></i>Change User Role
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ChangeRole" method="post" id="roleForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="userId" name="userId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold">User</label>
                        <input type="text" id="userName" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label for="roleId" class="form-label fw-semibold">New Role</label>
                        <select id="roleId" name="roleId" class="form-select" required>
                            <option value="">-- Select a role --</option>
                            <option value="1">Admin</option>
                            <option value="2">Customer</option>
                            <option value="3">Teller</option>
                            <option value="4">Manager</option>
                            <option value="5">Auditor</option>
                        </select>
                    </div>

                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle me-2"></i>
                        The user will receive a notification about the role change.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Change Role
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function setUserRole(userId, userName, currentRole) {
        document.getElementById('userId').value = userId;
        document.getElementById('userName').value = userName;
        // Reset the select
        document.getElementById('roleId').value = '';
    }

    // Initialize tooltips
    document.addEventListener('DOMContentLoaded', function() {
        const tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltips.forEach(el => {
            new bootstrap.Tooltip(el);
        });
    });
</script>
