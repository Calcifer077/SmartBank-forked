@model SmartBank.MVC.ViewModels.AdminTicketListViewModel
@{ ViewData["Title"] = "Support Tickets"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-headset me-2"></i>All Support Tickets
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Dashboard
    </a>
</div>

<div class="d-flex gap-2 mb-4">
    <span class="badge bg-danger fs-6 px-3 py-2">
        Open: @Model.Tickets.Count(t => t.Status == "Open")
    </span>
    <span class="badge bg-success fs-6 px-3 py-2">
        Resolved: @Model.Tickets.Count(t => t.Status == "Resolved")
    </span>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Customer</th>
                    <th>Subject</th>
                    <th>Status</th>
                    <th>Raised On</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    var statusColor = ticket.Status == "Resolved" ? "success" : "danger";

                    <tr>
                        <td class="ps-4 text-muted small">#@ticket.TicketId</td>
                        <td class="fw-semibold small">@ticket.ApplicantName</td>
                        <td>
                            <div class="small fw-semibold">@ticket.Subject</div>
                            <div class="text-muted" style="font-size:.75rem">
                                @(ticket.Description.Length > 50
                                    ? ticket.Description[..50] + "..."
                                    : ticket.Description)
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-@statusColor">@ticket.Status</span>
                        </td>
                        <td class="small text-muted">
                            @ticket.CreatedAt.ToString("dd MMM yyyy")
                        </td>
                        <td class="text-end pe-4">
                            @if (ticket.Status != "Resolved")
                            {
                                <form asp-action="ResolveTicket" method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ticketId"
                                           value="@ticket.TicketId" />
                                    <button class="btn btn-success btn-sm">
                                        <i class="bi bi-check-circle me-1"></i>Resolve
                                    </button>
                                </form>
                            }
                            else
                            {
                                <small class="text-muted">
                                    @ticket.ResolvedAt?.ToString("dd MMM")
                                </small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>