@model SmartBank.MVC.ViewModels.DepositWithdrawViewModel
@{ ViewData["Title"] = "Deposit"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center mt-2">
    <div class="col-md-6">
        <div class="card p-4">
            <div class="text-center mb-4">
                <i class="bi bi-plus-circle text-success" style="font-size:2.5rem"></i>
                <h4 class="mt-2 fw-bold">Deposit Funds</h4>
                <p class="text-muted small">Add money to your account</p>
            </div>

            <!-- Account Info Banner -->
            <div class="alert alert-light border d-flex justify-content-between mb-4">
                <div>
                    <small class="text-muted d-block">Account</small>
                    <span class="fw-semibold font-monospace">@Model.AccountNumber</span>
                    <span class="badge bg-primary ms-2">@Model.AccountType</span>
                </div>
                <div class="text-end">
                    <small class="text-muted d-block">Current Balance</small>
                    <span class="fw-bold text-success">₹@Model.CurrentBalance.ToString("N2")</span>
                </div>
            </div>

            <form asp-action="Deposit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AccountId" />
                <input type="hidden" asp-for="AccountNumber" />
                <input type="hidden" asp-for="AccountType" />
                <input type="hidden" asp-for="CurrentBalance" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Amount" class="form-label fw-semibold">
                        Amount (₹)
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input asp-for="Amount" type="number" step="0.01" min="1"
                               class="form-control form-control-lg"
                               placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>

                <!-- Quick amount buttons -->
                <div class="mb-3">
                    <small class="text-muted d-block mb-2">Quick amounts</small>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var amt in new[] { 500, 1000, 5000, 10000, 25000 })
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm quick-amt"
                                    data-amount="@amt">
                                ₹@amt.ToString("N0")
                            </button>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">
                        Description
                    </label>
                    <input asp-for="Description" class="form-control"
                           placeholder="e.g. Salary, savings..." />
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success flex-grow-1">
                        <i class="bi bi-check-circle me-1"></i> Confirm Deposit
                    </button>
                    <a asp-controller="Accounts" asp-action="Detail"
                       asp-route-id="@Model.AccountId"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.quick-amt').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('Amount').value = btn.dataset.amount;
            });
        });
    </script>
}