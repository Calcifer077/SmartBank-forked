@model SmartBank.MVC.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="login-container">
    <div class="col-lg-5 col-md-6 col-sm-8">
        <div class="card login-card">
            <div class="card-body p-5">
                <!-- Register Header -->
                <div class="login-header">
                    <div class="icon">
                        <i class="bi bi-person-plus"></i>
                    </div>
                    <h4>Join SmartBank</h4>
                    <p class="text-muted small">Create your account today</p>
                </div>

                <!-- Register Form -->
                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:none;"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold mb-2">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                <i class="bi bi-person text-muted"></i>
                            </span>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" style="border-radius: 0 8px 8px 0;" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold mb-2">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" style="border-radius: 0 8px 8px 0;" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="Password" class="form-label fw-semibold mb-2">Password</label>
                            <div class="input-group">
                                <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" class="form-control" placeholder="Min 8 chars" style="border-radius: 0 8px 8px 0;" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold mb-2">Confirm</label>
                            <div class="input-group">
                                <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                    <i class="bi bi-lock-check text-muted"></i>
                                </span>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat" style="border-radius: 0 8px 8px 0;" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold mb-2">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                <i class="bi bi-telephone text-muted"></i>
                            </span>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="9876543210" style="border-radius: 0 8px 8px 0;" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-semibold mb-2">
                            Address <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius: 8px 0 0 8px; border: 2px solid #e9ecef; background: transparent;">
                                <i class="bi bi-geo-alt text-muted"></i>
                            </span>
                            <input asp-for="Address" class="form-control" placeholder="123 Main St" style="border-radius: 0 8px 8px 0;" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login w-100 mb-3">
                        <i class="bi bi-person-check me-2"></i> Create Account
                    </button>
                </form>

                <!-- Divider -->
                <div class="divider">
                    <span>Already registered?</span>
                </div>

                <!-- Login Link -->
                <div class="register-link">
                    <p class="text-muted small mb-0">
                        <a asp-controller="Auth" asp-action="Login">Sign in to your account</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>